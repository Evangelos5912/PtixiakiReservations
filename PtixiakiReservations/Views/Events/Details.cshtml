@model PtixiakiReservations.Models.Event

@{
    ViewData["Title"] = "Event Details";
    var displayDescription = Model.Description ?? Model.ParentEvent?.Description;
    var hasSchedules = Model.ParentEventId == null && Model.ChildEvents != null && Model.ChildEvents.Any();
}

<div class="container mx-auto px-4 py-8 max-w-9xl">
    <div class="bg-white rounded-xl shadow-lg overflow-hidden relative">
        <!-- Header with gradient background -->
        <div class="bg-gradient-to-r from-blue-600 to-indigo-700 py-6 px-8">
            <h1 class="text-3xl font-bold text-white">@Model.Name</h1>
        </div>

        <div class="overflow-hidden">
           @{
            var finalPath = !string.IsNullOrEmpty(Model.DisplayImagePath) 
                ? Model.DisplayImagePath 
                : Model.ParentEvent?.DisplayImagePath;
            }

            @if (!string.IsNullOrEmpty(finalPath))
                    {
                        <img src="@finalPath" class="w-full h-full object-cover transform hover:scale-105 transition-transform duration-300" />
                    }
                    else
                    {
                        <div data-type="@Model.EventType.Name" class="event-icon flex items-center justify-center h-full text-gray-400"></div>
                    }
        </div>

        <!-- STICKY ANIMATED MENU -->
        <div class="sticky top-0 z-40 bg-white/95 backdrop-blur-sm border-b border-gray-200 shadow-sm w-full">
            <nav class="flex px-8 py-4 space-x-8 overflow-x-auto hide-scrollbar">
                <a href="#general-info" class="text-sm font-bold text-gray-600 hover:text-blue-600 uppercase tracking-wider transition-colors relative group py-1">
                    General Info
                    <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-600 transition-all duration-300 ease-out group-hover:w-full"></span>
                </a>
                
                @if (displayDescription != null)
                {
                    <a href="#descriptionArea" class="text-sm font-bold text-gray-600 hover:text-blue-600 uppercase tracking-wider transition-colors relative group py-1">
                        Description
                        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-600 transition-all duration-300 ease-out group-hover:w-full"></span>
                    </a>
                }
                
                @if (Model.Organizer != null)
                {
                    <a href="#OrganizerInfo" class="text-sm font-bold text-gray-600 hover:text-blue-600 uppercase tracking-wider transition-colors relative group py-1">
                        Organizer
                        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-600 transition-all duration-300 ease-out group-hover:w-full"></span>
                    </a>
                }
                
                @if (hasSchedules)
                {
                    <a href="#available-schedules" class="text-sm font-bold text-gray-600 hover:text-blue-600 uppercase tracking-wider transition-colors relative group py-1">
                        Schedules
                        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-600 transition-all duration-300 ease-out group-hover:w-full"></span>
                    </a>
                }
            </nav>
        </div>

        <div class="p-6">
            <div id="general-info" class="grid grid-cols-1 lg:grid-cols-2 gap-8 mt-6 mb-8 scroll-mt-24">
                
                <!-- LEFT COLUMN - Blue Info Box -->
                <div class="bg-blue-50 p-8 rounded-xl flex flex-col gap-6 border border-blue-100 shadow-sm h-full">
                    
                    <!-- Date & Time -->
                    <div class="flex items-start">
                        <svg class="h-6 w-6 text-blue-600 mr-4 mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        <div>
                            @if (Model.StartDateTime.Date != Model.EndTime.Date)
                            {
                                <h3 class="text-lg font-semibold text-gray-900">
                                    @Model.StartDateTime.ToString("MMM d, yyyy") - @Model.EndTime.ToString("MMM d, yyyy")
                                </h3>
                            }
                            else
                            {
                                <h3 class="text-lg font-semibold text-gray-900">
                                    @Model.StartDateTime.ToString("dddd, MMMM d, yyyy") 
                                </h3>
                                <p class="text-gray-700 mt-1 font-medium">
                                    @Model.StartDateTime.ToString("h:mm tt") - @Model.EndTime.ToString("h:mm tt")
                                </p>
                            }
                        </div>
                    </div>

                    <!-- Location -->
                    @if (Model.Venue != null)
                    {
                        <div class="border-t border-blue-200/70"></div>

                        <div class="flex items-start">
                            <svg class="h-6 w-6 text-blue-600 mr-4 mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            <div>
                                @{
                                    bool hasMultipleLocations = false;
                                    bool differsFromParentLocation = false; 
                                    
                                    if (Model.ChildEvents != null && Model.ChildEvents.Any())
                                    {
                                        var childVenueIds = Model.ChildEvents
                                            .Where(c => c.VenueId != null)
                                            .Select(c => c.VenueId)
                                            .Distinct()
                                            .ToList();
                                            
                                        hasMultipleLocations = childVenueIds.Count > 1;
                                        differsFromParentLocation = childVenueIds.Any(vid => vid != Model.VenueId);
                                    }
                                }

                                @if (hasMultipleLocations || differsFromParentLocation)
                                {
                                    <h3 class="text-lg font-semibold text-gray-900">Multiple Locations</h3>
                                    <p class="text-gray-700 mt-1">This event takes place across several venues.</p>
                                    <a href="#available-schedules" class="inline-flex items-center mt-2 text-blue-700 hover:text-blue-900 font-medium transition-colors">
                                        Check schedule below ↓
                                    </a>
                                }
                                else
                                {
                                    <h3 class="text-lg font-semibold text-gray-900">Location</h3>
                                    <p class="text-gray-800 mt-1 font-medium">@Model.Venue.Name</p>
                                    
                                    @if (Model.Venue.Address != null && Model.Venue.City != null)
                                    {
                                        <p class="text-gray-600">@Model.Venue.Address, @Model.Venue.City.Name</p>
                                        <!-- FIX: Added explicit Razor parentheses () around the Uri string to prevent VSC parser errors -->
                                        <a href="https://maps.google.com/?q=@(Uri.EscapeDataString($"{Model.Venue.Name}, {Model.Venue.Address}, {Model.Venue.City.Name}"))" 
                                        target="_blank" 
                                        rel="noopener noreferrer"
                                        class="inline-flex items-center mt-3 text-blue-700 hover:text-blue-900 font-medium transition-colors">
                                            View on Google Maps
                                            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                        </a>
                                    } 
                                }
                            </div>
                        </div>
                    }

                    <!-- Event Type -->
                    @if (Model.EventType != null)
                    {
                        <div class="border-t border-blue-200/70"></div>

                        <div class="flex items-start">
                            <svg class="h-6 w-6 text-blue-600 mr-4 mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                            </svg>
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900">Event Type</h3>
                                <p class="text-gray-700 mt-1 font-medium">@Model.EventType.Name</p>
                            </div>
                        </div>
                    }
                </div>

                <!-- RIGHT COLUMN - Action Card -->
                <div>
                    <!-- sticky top-24 keeps the reservation box visible below the nav menu -->
                    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-8 sticky top-24">
                        @if(Model.ParentEventId != null || Model.ChildEvents == null || !Model.ChildEvents.Any()){
                            <div class="text-center">
                                <h3 class="text-2xl font-bold text-gray-900 mb-2">Reserve Your Spot</h3>
                                <p class="text-gray-600 mb-6">Select your preferred seats and secure your tickets now.</p>
                                
                                <a href="@Url.Action("ReserveSeats", "Reservation", new { eventId = Model.Id })"
                                class="w-full block text-center px-6 py-4 bg-blue-600 text-white font-semibold text-lg rounded-lg shadow-md hover:bg-blue-700 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all duration-200 transform hover:-translate-y-1">
                                    Reserve Seats
                                </a>
                                
                                <p class="text-sm text-gray-500 mt-4 flex items-center justify-center">
                                    <svg class="w-4 h-4 mr-1 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                                    Secure checkout available
                                </p>
                            </div>
                        }
                        else{
                            <div class="text-center">
                                <h3 class="text-2xl font-bold text-gray-900 mb-2">Reserve Your Spot</h3>
                                
                                <a href="#available-schedules"
                                class="w-full block text-center px-6 py-4 bg-blue-600 text-white font-semibold text-lg rounded-lg shadow-md hover:bg-blue-700 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all duration-200 transform hover:-translate-y-1">
                                    Select a Schedule
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @if (displayDescription != null)
            {
            <div id="descriptionArea" class="mt-8 w-full scroll-mt-24">
                <h3 class="text-lg font-semibold text-gray-900 mb-4 border-b pb-2">Description</h3>
                <div class="relative">
                    <p id="event-description" class="text-gray-600 mb-2 break-words leading-relaxed whitespace-pre-wrap custom-line-clamp">@displayDescription</p>
                    
                    <button id="toggle-description-btn" class="hidden text-blue-600 hover:text-blue-800 font-medium text-sm focus:outline-none flex items-center transition-colors mt-2">
                        <span>Read More</span>
                        <svg class="w-4 h-4 ml-1 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                    </button>
                </div>
            </div>
            }
            
            <div class="relative w-full h-[300px] md:h-[450px] lg:h-[600px] group overflow-hidden bg-gray-100 rounded-xl mt-8" id="gallery-container" data-event-id="@Model.Id" data-event-type="@Model.EventType?.Name">
                
                <div id="carousel-track" class="flex w-full h-full overflow-x-auto scroll-smooth snap-x snap-mandatory scrollbar-hide">
                    <div id="gallery-fallback" class="w-full h-full flex-none flex items-center justify-center bg-gray-100">
                        <div class="animate-pulse text-indigo-500 font-bold text-lg">Loading images...</div>
                    </div>
                </div>

                <button id="btn-prev" type="button" class="hidden absolute left-4 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white p-2 rounded-full shadow-lg transition-all opacity-0 group-hover:opacity-100 z-10">
                    <svg class="w-6 h-6 text-gray-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </button>
                <button id="btn-next" type="button" class="hidden absolute right-4 top-1/2 -translate-y-1/2 bg-white/80 hover:bg-white p-2 rounded-full shadow-lg transition-all opacity-0 group-hover:opacity-100 z-10">
                    <svg class="w-6 h-6 text-gray-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </button>
            </div>
           

            @if(Model.Organizer != null){
                <div id="OrganizerInfo" class="mt-8 lg:w-1/2 rounded-xl border border-gray-200 bg-gray-50 shadow-sm p-6 scroll-mt-24">
                    <div class="flex items-center mb-4 border-b border-gray-200 pb-3">
                        <div class="bg-indigo-100 p-2 rounded-full mr-3 text-indigo-600">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-gray-900">Organizer</h3>
                            <p class="text-indigo-600 font-medium text-sm">@Model.Organizer.FirstName @Model.Organizer.LastName</p>
                        </div>
                    </div>
                    
                    <div class="space-y-3">
                        <div class="grid grid-cols-3 items-center">
                            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Phone:</h3>
                            <p class="col-span-2 text-gray-900 font-medium">@Model.Organizer.PhoneNumber</p>
                        </div>
                        <div class="grid grid-cols-3 items-center">
                            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Email:</h3>
                            <p class="col-span-2 text-gray-900 font-medium break-words">@Model.Organizer.Email</p>
                        </div>
                        <div class="grid grid-cols-3 items-center">
                            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Address:</h3>
                            <p class="col-span-2 text-gray-900 font-medium">@(string.IsNullOrWhiteSpace(Model.Organizer.Address) ? "Not Provided" : Model.Organizer.Address)</p>
                        </div>
                        <div class="grid grid-cols-3 items-center">
                            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Zip Code:</h3>
                            <p class="col-span-2 text-gray-900 font-medium">@(string.IsNullOrWhiteSpace(Model.Organizer.PostalCode) ? "Not Provided" : Model.Organizer.PostalCode)</p>
                        </div>
                    </div>
                </div>
            }
            
        </div>
    </div>
    
    <!-- Sub Events -->
    @if(hasSchedules){
        var schedulePageSize = 10;
        var schedulePage = 1;
        var orderedChildEvents = Model.ChildEvents.OrderBy(s => s.StartDateTime).ToList();
        var totalSchedulePages = (int)Math.Ceiling(orderedChildEvents.Count / (double)schedulePageSize);

        if (int.TryParse(Context.Request.Query["schedulePage"], out var requestedSchedulePage))
        {
            schedulePage = requestedSchedulePage;
        }

        schedulePage = Math.Clamp(schedulePage, 1, totalSchedulePages);

        var pagedChildEvents = orderedChildEvents
            .Skip((schedulePage - 1) * schedulePageSize)
            .Take(schedulePageSize)
            .ToList();

        <div id="available-schedules" class="overflow-x-auto mt-10 rounded-xl shadow-lg scroll-mt-24">
            <div class="bg-gray-50 px-8 py-5 border-b border-gray-200 flex justify-between items-center">
                <h2 class="text-xl font-bold text-gray-800">Available Schedules</h2>
                <span class="bg-blue-100 text-blue-800 text-l font-semibold px-3 py-1 rounded-full">
                    @Model.ChildEvents.Count
                </span>
            </div>
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-white text-gray-500 text-xs uppercase tracking-wider border-b border-gray-200">
                            <th class="px-6 py-4 font-semibold">Date</th>
                            <th class="px-6 py-4 font-semibold">Time</th>
                            <th class="px-8 py-4 font-semibold">Event Name</th>
                            <th class="px-6 py-4 font-semibold">Location</th>
                            <th class="px-6 py-4 font-semibold">Layout</th>
                            <th class="px-8 py-4 font-semibold text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                    @foreach(var child in pagedChildEvents){
                        <tr class="hover:bg-blue-50/50 transition-colors group bg-white border-b border-gray-200 mt-5 ">
                            <td class="px-6 py-4">
                                <div class="flex items-center text-sm text-gray-600">
                                    <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                    @child.StartDateTime.ToString("MMM d, yyyy")
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center text-sm text-gray-600">
                                    <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    @child.StartDateTime.ToString("h:mm tt")
                                </div>
                            </td>
                            <td class="px-8 py-4">
                                <p class="font-medium text-gray-900 break-words">@child.Name</p>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-600 break-words">
                                @(child.Venue?.Name ?? "Main Location")
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-600 break-words">
                                @(child.SubArea?.AreaName ?? "Main Layout")
                            </td>
                            <td class="px-8 py-4 text-right">
                                <a href="@Url.Action("Details", "Events", new { id = child.Id })" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-blue-700 bg-blue-100 hover:bg-blue-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors">
                                    View & Reserve
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (totalSchedulePages > 1)
            {
                <div class="bg-white px-8 py-5 border-t border-gray-200 flex items-center justify-center gap-2">
                    @if (schedulePage > 1)
                    {
                        <a href="@(Url.Action("Details", "Events", new { id = Model.Id, schedulePage = schedulePage - 1 }) + "#available-schedules")"
                           class="px-3 py-2 text-sm font-medium rounded-md border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors">
                            Previous
                        </a>
                    }

                    @for (var pageNumber = 1; pageNumber <= totalSchedulePages; pageNumber++)
                    {
                        if (pageNumber == schedulePage)
                        {
                            <span class="min-w-10 px-3 py-2 text-sm font-semibold rounded-md bg-blue-600 text-white text-center">
                                @pageNumber
                            </span>
                        }
                        else
                        {
                            <a href="@(Url.Action("Details", "Events", new { id = Model.Id, schedulePage = pageNumber }) + "#available-schedules")"
                               class="min-w-10 px-3 py-2 text-sm font-medium rounded-md border border-gray-300 text-gray-700 text-center hover:bg-gray-50 transition-colors">
                                @pageNumber
                            </a>
                        }
                    }

                    @if (schedulePage < totalSchedulePages)
                    {
                        <a href="@(Url.Action("Details", "Events", new { id = Model.Id, schedulePage = schedulePage + 1 }) + "#available-schedules")"
                           class="px-3 py-2 text-sm font-medium rounded-md border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors">
                            Next
                        </a>
                    }
                </div>
            }
        </div>
    }

    <!-- Back Button -->
    <div class="mt-8">
        <a href="@Url.Action("EventsForToday", "Events")" class="inline-flex items-center text-blue-600 hover:text-blue-800 transition-colors font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Events
        </a>
    </div>
</div>

<style>
    html { scroll-behavior: smooth; }
    .scrollbar-hide::-webkit-scrollbar { display: none; }

    .custom-line-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 10;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }

</style>

@section Scripts {
<script type="module">
    import { getEventSvg } from "/js/event-svg.js";

    const track = document.getElementById('carousel-track');
    const btnPrev = document.getElementById('btn-prev');
    const btnNext = document.getElementById('btn-next');
    if (btnPrev && btnNext && track) {
        btnPrev.addEventListener('click', function() {
            track.scrollBy({ left: -track.offsetWidth, behavior: 'smooth' });
        });
        btnNext.addEventListener('click', function() {
            track.scrollBy({ left: track.offsetWidth, behavior: 'smooth' });
        });
    }
 

    // 2. Main fetch logic
    async function loadGallery() {
        const container = document.getElementById('gallery-container');
        if (!container) return;

        const eventId = container.dataset.eventId;
        const eventType = container.dataset.eventType || "";
        const track = document.getElementById('carousel-track');
        
        const apiUrl = `@Url.Action("GetEventGallery", "Events")?eventId=${eventId}`;

        try {
            const response = await fetch(apiUrl);
            if (!response.ok) throw new Error(`Server returned ${response.status}`);

            const data = await response.json();

            if (data.success && data.images && data.images.length > 0) {
                track.innerHTML = ''; 
                
                data.images.forEach(path => {
                    const slide = document.createElement('div');
                    
                    slide.className = 'w-full h-full flex-none snap-center flex items-center justify-center';
                    
                    slide.innerHTML = '<img src="' + path + '" class="max-w-full max-h-full object-contain drop-shadow-md" />';
                    
                    track.appendChild(slide);
                });

                if (data.images.length > 1) {
                    document.getElementById('btn-prev').classList.remove('hidden');
                    document.getElementById('btn-next').classList.remove('hidden');
                }
            } else {
                track.innerHTML = `
                    <div class="w-full h-full flex-none flex items-center justify-center bg-gray-100">
                        <div class="event-icon h-24 w-24 text-gray-400">
                            ${getEventSvg(eventType.toLowerCase())}
                        </div>
                    </div>`;
            }
        } catch (error) {
            console.error("Gallery Load Failed:", error);
            track.innerHTML = `
                <div class="w-full h-full flex-none flex flex-col items-center justify-center bg-red-50 text-red-500 p-6 text-center">
                    <span class="font-bold">Error loading gallery</span>
                    <span class="text-sm mt-1 text-red-400">${error.message}</span>
                </div>`;
        }
    }

    // 3. Run the scripts
    loadGallery();

    document.querySelectorAll(".event-icon:not(#carousel-track .event-icon)").forEach(el => {
        const type = el.dataset.type || "";
        el.innerHTML = getEventSvg(type.toLowerCase());
    });

    const descEl = document.getElementById('event-description');
    const toggleBtn = document.getElementById('toggle-description-btn');
    
    if (descEl && toggleBtn) {

        setTimeout(() => {

            descEl.classList.remove('custom-line-clamp');
            const fullHeight = descEl.scrollHeight;
            

            descEl.classList.add('custom-line-clamp');
            const clampedHeight = descEl.clientHeight;
            

            if (fullHeight > clampedHeight + 10) {
                toggleBtn.classList.remove('hidden');
            }
        }, 100);

        toggleBtn.addEventListener('click', function() {
            const isClamped = descEl.classList.contains('custom-line-clamp');
            const span = toggleBtn.querySelector('span');
            const icon = toggleBtn.querySelector('svg');
            
            if (isClamped) {
                descEl.classList.remove('custom-line-clamp');
                span.innerText = 'Read Less';
                icon.classList.add('rotate-180');
            } else {
                descEl.classList.add('custom-line-clamp');
                span.innerText = 'Read More';
                icon.classList.remove('rotate-180');
            }
        });
    }
</script>
}