@model PtixiakiReservations.Models.Event

@{
    ViewData["Title"] = "Reserve Seats";
    var venueId = Model.Venue.Id;
    var eventId = Model.Id;
    var subAreaId = Model.SubAreaId;
}

<div class="container mx-auto px-4 py-8 max-w-6xl">
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
        <!-- Header with gradient background -->
        <div class="bg-gradient-to-r from-blue-600 to-indigo-700 py-6 px-8">
            <h1 class="text-3xl font-bold text-white">Reserve Seats</h1>
            <p class="text-blue-100 mt-2">@Model.Name</p>
            @if (Model.SubArea != null)
            {
                <p class="text-blue-200 text-sm mt-1">Layout: @Model.SubArea.AreaName</p>
            }
        </div>

        <div class="p-6">
            <!-- Event Summary & Time Selection -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <!-- Event Summary -->
                <div class="md:col-span-1 bg-blue-50 p-5 rounded-lg">
                    <h3 class="text-lg font-semibold text-gray-800 mb-3">Event Details</h3>

                    <div class="space-y-3">
                        <div class="flex items-start">
                            <svg class="h-5 w-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                            <div>
                                <p class="text-sm text-gray-700">
                                    @Model.StartDateTime.ToString("dddd, MMMM d, yyyy")
                                </p>
                                <p class="text-sm text-gray-600">
                                    @Model.StartDateTime.ToString("h:mm tt") - @Model.EndTime.ToString("h:mm tt")
                                </p>
                            </div>
                        </div>

                        <div class="flex items-start">
                            <svg class="h-5 w-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            <div>
                                <p class="text-sm text-gray-700">@Model.Venue.Name</p>
                                @if (Model.Venue.City != null)
                                {
                                    <p class="text-sm text-gray-600">@Model.Venue.City.Name</p>
                                }
                                @if (Model.SubArea != null)
                                {
                                    <p class="text-sm text-gray-600">Area: @Model.SubArea.AreaName</p>
                                }
                            </div>
                        </div>

                        @if (Model.EventType != null)
                        {
                            <div class="flex items-start">
                                <svg class="h-5 w-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                                </svg>
                                <p class="text-sm text-gray-700">@Model.EventType.Name</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Time Selection -->
                <div class="md:col-span-2 bg-blue-50 p-5 rounded-lg">
                    <h3 class="text-lg font-semibold text-gray-800 mb-3">Reservation Time</h3>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <!-- Time inputs (hidden by default) -->
                        <div class="hidden">
                            <input type="hidden" id="startTime" value="@Model.StartDateTime.TimeOfDay" />
                            <input type="hidden" id="endTime" value="@Model.EndTime.TimeOfDay" />
                            <input type="hidden" id="eventDate" value="@Model.StartDateTime.ToString("yyyy-MM-dd")" />
                            <input type="hidden" id="subAreaId" value="@subAreaId" />
                            <input type="hidden" id="eventId" value="@eventId" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Start Time</label>
                            <div class="flex items-center space-x-3">
                                <input class="form-input w-full rounded-md shadow-sm border-gray-300 bg-white text-gray-800"
                                       type="time" id="reservationStartTime"
                                       value="@Model.StartDateTime.ToString("HH:mm")" />
                                <div class="flex items-center">
                                    <input type="checkbox" id="useEventStartTime" class="h-4 w-4 text-blue-600 border-gray-300 rounded" checked>
                                    <label for="useEventStartTime" class="ml-2 text-sm text-gray-700">From Start</label>
                                </div> 
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">End Time</label>
                            <div class="flex items-center space-x-3">
                                <input class="form-input w-full rounded-md shadow-sm border-gray-300 bg-white text-gray-800"
                                       type="time" id="reservationEndTime"
                                       value="@Model.EndTime.ToString("HH:mm")" />
                                <div class="flex items-center">
                                    <input type="checkbox" id="useEventEndTime" class="h-4 w-4 text-blue-600 border-gray-300 rounded" checked>
                                    <label for="useEventEndTime" class="ml-2 text-sm text-gray-700">Until End</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Only show Layout message if no Layout is set -->
            @if (subAreaId == null || subAreaId == 0)
            {
                <div class="mb-8 bg-yellow-50 border border-yellow-200 rounded-lg p-6">
                    <div class="flex items-center">
                        <svg class="h-6 w-6 text-yellow-600 mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
                        </svg>
                        <div>
                            <h3 class="text-yellow-800 font-medium">No Layout Selected</h3>
                            <p class="text-yellow-700 text-sm mt-1">This event doesn't have a specific Layout assigned. Seat selection is not available.</p>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="mb-8">
                    <h3 class="text-xl font-semibold text-gray-800 mb-4">Select Your Seats</h3>

                    <div class="mb-6 flex justify-center">
                        <div class="relative w-full border-2 border-gray-200 rounded-lg bg-gray-50 overflow-hidden" style="height: 600px;">
                            
                            <div class="absolute bottom-4 right-4 z-50 flex items-center gap-1 bg-white p-1.5 rounded-lg shadow-md border border-gray-200">
                                <button type="button" onclick="ZoomOut()" class="p-1.5 hover:bg-gray-100 rounded text-gray-600 transition-colors" title="Zoom Out">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM13 10H7"/></svg>
                                </button>
                                <span id="zoom-level" class="w-12 text-center text-sm font-bold text-gray-700 select-none">100%</span>
                                <button type="button" onclick="ZoomIn()" class="p-1.5 hover:bg-gray-100 rounded text-gray-600 transition-colors" title="Zoom In">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
                                </button>
                                <div class="w-px h-5 bg-gray-300 mx-1"></div>
                                <button type="button" onclick="ResetZoom()" class="p-1.5 hover:bg-gray-100 rounded text-gray-600 transition-colors" title="Reset Zoom">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                                </button>
                            </div>

                            <div class="w-full h-full overflow-auto bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:20px_20px]">
                                <canvas id="seatCanvas"></canvas>
                            </div>
                            
                        </div>
                    </div>

                    <!-- Legend with improved styling -->
                    <div class="mb-6 bg-gray-50 p-4 rounded-lg">
                        <h3 class="text-center text-gray-700 font-semibold mb-3">Seat Legend</h3>
                        <div class="flex justify-center flex-wrap gap-6">
                            <div class="flex items-center">
                                <div class="w-5 h-5 bg-green-500 rounded mr-2 shadow-sm"></div>
                                <span class="text-sm text-gray-700">Available</span>
                            </div>
                            <div class="flex items-center">
                                <div class="w-5 h-5 bg-red-500 rounded mr-2 shadow-sm"></div>
                                <span class="text-sm text-gray-700">Unavailable</span>
                            </div>
                            <div class="flex items-center">
                                <div class="w-5 h-5 bg-blue-500 rounded mr-2 shadow-sm"></div>
                                <span class="text-sm text-gray-700">Selected</span>
                            </div>
                        </div>
                    </div>

                    <!-- Selected seats summary -->
                    <div id="selection-summary" class="mb-6 hidden">
                        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                            <h3 class="text-blue-800 font-medium mb-2">Your Selection</h3>
                            <div class="flex items-center">
                                <div class="mr-3">
                                    <span id="selected-count" class="text-2xl font-bold text-blue-600">0</span>
                                    <span class="text-blue-600">seats</span>
                                </div>
                                <div id="selected-seats-list" class="text-sm text-blue-800">
                                    <!-- Will be populated by JavaScript -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Action buttons -->
                <div class="flex flex-col sm:flex-row gap-3 justify-center">
                    <button id="clear-selection" class="px-5 py-3 border border-gray-300 text-gray-700 font-medium rounded-md shadow-sm hover:bg-gray-50 transition-duration-150 hidden">
                        Clear Selection
                    </button>

                    <button id="confirm-reservation" class="px-6 py-3 bg-blue-600 text-white font-medium rounded-md shadow-md hover:bg-blue-700 transition-duration-150 flex items-center justify-center">
                        <span>Complete Reservation</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- Back Button -->
    <div class="mt-8">
        <a href="@Url.Action("Details", "Events", new { id = Model.Id })" class="inline-flex items-center text-blue-600 hover:text-blue-800 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Event Details
        </a>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.0/fabric.min.js"></script>
    <script>
        const eventId = @eventId;
        const venueId = @venueId;
        const subAreaId = @(subAreaId ?? 0);
        let selectedSeats = [];
        let seatNames = {};
        let fabricCanvas;

        // --- ZOOM & PAN CONTROLS ---
        function updateZoomText() {
            const zoomText = document.getElementById('zoom-level');
            if (zoomText && fabricCanvas) {
                zoomText.textContent = `${Math.round(fabricCanvas.getZoom() * 100)}%`;
            }
        }

        function ZoomIn() {
            if (!fabricCanvas) return;
            let zoom = fabricCanvas.getZoom() * 1.1;
            if (zoom > 5) zoom = 5;
            fabricCanvas.zoomToPoint({ x: fabricCanvas.width / 2, y: fabricCanvas.height / 2 }, zoom);
            updateZoomText();
        }

        function ZoomOut() {
            if (!fabricCanvas) return;
            let zoom = fabricCanvas.getZoom() / 1.1;
            if (zoom < 0.1) zoom = 0.1;
            fabricCanvas.zoomToPoint({ x: fabricCanvas.width / 2, y: fabricCanvas.height / 2 }, zoom);
            updateZoomText();
        }

        function ResetZoom() {
            if (!fabricCanvas) return;
            fabricCanvas.setZoom(1);
            fabricCanvas.viewportTransform = [1, 0, 0, 1, 0, 0];
            fabricCanvas.requestRenderAll();
            updateZoomText();
        }

        function resizeCanvasToFitElements(seats, shapes) {
            if (!fabricCanvas) return;

            const minWidth = 800;
            const minHeight = 600;
            const padding = 100;

            let maxX = 0; let maxY = 0;

            if (seats && seats.length > 0) {
                maxX = Math.max(maxX, ...seats.map(s => (Number(s.x) || 0) + 60)); // Seat width is 60
                maxY = Math.max(maxY, ...seats.map(s => (Number(s.y) || 0) + 60));
            }
            if (shapes && shapes.length > 0) {
                maxX = Math.max(maxX, ...shapes.map(s => (Number(s.x) || 0) + (Number(s.width) || 0)));
                maxY = Math.max(maxY, ...shapes.map(s => (Number(s.y) || 0) + (Number(s.height) || 0)));
            }

            fabricCanvas.setWidth(Math.max(minWidth, maxX + padding));
            fabricCanvas.setHeight(Math.max(minHeight, maxY + padding));
            fabricCanvas.calcOffset();
        }

        // --- INITIALIZATION ---
        document.addEventListener('DOMContentLoaded', function () {
            fabricCanvas = new fabric.Canvas('seatCanvas', { selection: false });

            // Allow Canvas Panning by dragging empty space
            fabricCanvas.on('mouse:down', function (opt) {
                const evt = opt.e;
                if (!opt.target || (opt.target && opt.target.selectable === false && !opt.target.seatId)) {
                    this.isDragging = true;
                    this.lastPosX = evt.clientX;
                    this.lastPosY = evt.clientY;
                }
            });
            fabricCanvas.on('mouse:move', function (opt) {
                if (this.isDragging) {
                    const e = opt.e;
                    const vpt = this.viewportTransform;
                    vpt[4] += e.clientX - this.lastPosX;
                    vpt[5] += e.clientY - this.lastPosY;
                    this.requestRenderAll();
                    this.lastPosX = e.clientX;
                    this.lastPosY = e.clientY;
                }
            });
            fabricCanvas.on('mouse:up', function () {
                this.setViewportTransform(this.viewportTransform);
                this.isDragging = false;
            });

            // Mouse wheel zoom
            fabricCanvas.on('mouse:wheel', function(opt) {
                let delta = opt.e.deltaY;
                let zoom = fabricCanvas.getZoom() * (0.999 ** delta);
                if (zoom > 5) zoom = 5;
                if (zoom < 0.1) zoom = 0.1;
                fabricCanvas.zoomToPoint({ x: opt.e.offsetX, y: opt.e.offsetY }, zoom);
                opt.e.preventDefault();
                opt.e.stopPropagation();
                updateZoomText();
            });

            if (subAreaId && subAreaId !== 0) {
                loadSeatMap(subAreaId, eventId);
            }
        });

        async function loadSeatMap(subAreaId, eventId) {
            showLoadingOnFabric(fabricCanvas);

            try {
                const [seatRes, shapeRes] = await Promise.all([
                    fetch(`/Seat/get_data?SubAreaId=${subAreaId}&eventId=${eventId}`),
                    fetch(`/NonSelectable/GetElements?subAreaId=${subAreaId}`)
                ]);

                const seatData = seatRes.ok ? await seatRes.json() : [];
                const shapeData = shapeRes.ok ? await shapeRes.json() : [];

                fabricCanvas.clear();

                if ((seatData && seatData.length > 0) || (shapeData && shapeData.length > 0)) {
                    resizeCanvasToFitElements(seatData, shapeData);
                    renderMap(fabricCanvas, seatData, shapeData);
                } else {
                    showNoSeatsMessageOnFabric(fabricCanvas);
                }
            } catch (error) {
                console.error("Failed to load map data:", error);
                fabricCanvas.clear();
                showErrorMessageOnFabric(fabricCanvas);
            }
        }

        // --- UI & FORM LOGIC ---
        $(document).ready(function () {
            $("#useEventStartTime").on("change", function() {
                if ($(this).is(':checked')) {
                    $("#reservationStartTime").val('@Model.StartDateTime.ToString("HH:mm")');
                    $("#reservationStartTime").prop('disabled', true);
                } else {
                    $("#reservationStartTime").prop('disabled', false);
                }
            });

            $("#useEventEndTime").on("change", function() {
                 if ($(this).is(':checked')) {
                     $("#reservationEndTime").val('@Model.EndTime.ToString("HH:mm")');
                     $("#reservationEndTime").prop('disabled', true);
                 } else {
                     $("#reservationEndTime").prop('disabled', false);
                }
            });

            if ($("#useEventStartTime").is(':checked')) $("#reservationStartTime").prop('disabled', true);
            if ($("#useEventEndTime").is(':checked')) $("#reservationEndTime").prop('disabled', true);

            $("#confirm-reservation").on("click", function () {
                if (selectedSeats.length > 0) {
                    if (!subAreaId || subAreaId === 0) {
                        showNotification('No Layout assigned to this event.', 'warning');
                        return;
                    }

                    $(this).prop('disabled', true)
                        .html('<svg class="animate-spin -ml-1 mr-2 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Processing...');

                    const startTime = $("#useEventStartTime").is(":checked") ? $("#startTime").val() : $("#reservationStartTime").val();
                    const endTime = $("#useEventEndTime").is(":checked") ? $("#endTime").val() : $("#reservationEndTime").val();

                    const timeStart = new Date(`2000-01-01T${startTime}`);
                    const timeEnd = new Date(`2000-01-01T${endTime}`);
                    const difference = timeEnd - timeStart;

                    if (difference <= 0) {
                        showNotification('End time must be after start time.', 'error');
                        $(this).prop('disabled', false).html('<span>Complete Reservation</span>');
                        return;
                    }

                    const duration = `${Math.floor(difference / 3600000).toString().padStart(2, '0')}:${Math.floor((difference % 3600000) / 60000).toString().padStart(2, '0')}:${Math.floor((difference % 60000) / 1000).toString().padStart(2, '0')}`;
                    const reservationDate = `${$("#eventDate").val()}T${startTime}`;

                    $.ajax({
                        url: `/Reservation/MakeRes`,
                        type: "POST",
                        contentType: "application/json",
                        data: JSON.stringify({
                            seatIds: selectedSeats,
                            eventId: eventId,
                            subAreaId: subAreaId,
                            duration: duration,
                            resDate: reservationDate
                        }),
                        success: function() {
                            showNotification('Reservation successful!', 'success');
                            setTimeout(() => window.location.href = "/Reservation/Index", 1500);
                        },
                        error: function(xhr) {
                            $("#confirm-reservation").prop('disabled', false).html('<span>Complete Reservation</span>');
                            let msg = "Failed to reserve seats.";
                            try { msg = JSON.parse(xhr.responseText) || msg; } catch(e) { msg = xhr.responseText || msg; }
                            showNotification(msg, 'error');
                        }
                    });
                } else {
                    showNotification('Please select at least one seat.', 'warning');
                }
            });

            $("#clear-selection").on("click", () => clearAllSelections(fabricCanvas));
        });

        // --- MAP RENDERING (MATCHES DOM EDITOR 1:1) ---
        function renderMap(canvas, seats, shapes) {
            canvas.clear();

            // 1. Render Background Shapes (True to top-left coordinates)
            if (shapes) {
                shapes.forEach(shape => {
                    let fabricShape;
                    const fill = shape.backgroundColor || '#D1D5DB';
                    const width = shape.width || 100;
                    const height = shape.height || 100;

                    if (shape.shapeType === 'ellipse') {
                        fabricShape = new fabric.Ellipse({
                            rx: width / 2, ry: height / 2,
                            fill: fill, opacity: 0.8, stroke: '#9CA3AF', strokeWidth: 1,
                            originX: 'left', originY: 'top' 
                        });
                    } else if (shape.shapeType === 'triangle') {
                        fabricShape = new fabric.Triangle({
                            width: width, height: height, fill: fill, opacity: 0.8,
                            originX: 'left', originY: 'top'
                        });
                    } else {
                        fabricShape = new fabric.Rect({
                            width: width, height: height,
                            fill: fill, opacity: 0.8, stroke: '#9CA3AF', strokeWidth: 1,
                            originX: 'left', originY: 'top'
                        });
                    }

                    // Text sits dead center of the shape dimensions
                    const shapeText = new fabric.Text(shape.name, {
                        originX: 'center', originY: 'center',
                        left: width / 2, top: height / 2,
                        fill: fill === '#4B5563' ? '#FFFFFF' : '#1F2937', 
                        fontSize: 14, fontFamily: 'Arial', fontWeight: 'bold'
                    });
                    
                    if (shape.shapeType === 'triangle') shapeText.set('top', height / 1.5);

                    const shapeGroup = new fabric.Group([fabricShape, shapeText], {
                        left: shape.x, top: shape.y,
                        selectable: false, evented: false
                    });
                    canvas.add(shapeGroup);
                });
            }

            // 2. Render Seats (True 60x60 DOM dimensions)
            if (seats) {
                seats.forEach(seat => {
                    seatNames[seat.id] = seat.name;
                    
                    const seatRect = new fabric.Rect({
                        width: 60, height: 60, 
                        fill: seat.available ? '#4CAF50' : '#f44336', 
                        stroke: '#333', strokeWidth: 1, rx: 5, ry: 5,
                        originX: 'left', originY: 'top'
                    });

                    // Text sits dead center of the 60x60 rect
                    const seatText = new fabric.Text(seat.name, {
                        originX: 'center', originY: 'center',
                        left: 30, top: 30,
                        fill: 'white', fontSize: 11, fontFamily: 'Arial'
                    });

                    const seatGroup = new fabric.Group([seatRect, seatText], {
                        left: seat.x, top: seat.y,
                        selectable: seat.available,

                        hasControls: false, 
                        hasBorders: false,
                        lockMovementX: true, 
                        lockMovementY: true,
                        lockRotation: true,
                        lockScalingX: true,
                        lockScalingY: true,
                        
                        hoverCursor: seat.available ? 'pointer' : 'default'
                    });

                    seatGroup.seatId = seat.id;
                    seatGroup.seatName = seat.name;
                    seatGroup.available = seat.available;

                    if (seat.available) {
                        seatGroup.on('mousedown', function() { toggleSeatSelection(this, canvas); });
                    }
                    canvas.add(seatGroup);
                });
            }
            canvas.renderAll();
        }

        function toggleSeatSelection(seatGroup, canvas) {
            const seatId = seatGroup.seatId;
            const rect = seatGroup.item(0);

            if (selectedSeats.includes(seatId)) {
                selectedSeats = selectedSeats.filter(id => id !== seatId);
                rect.set('fill', '#4CAF50'); 
            } else {
                selectedSeats.push(seatId);
                rect.set('fill', '#2196F3'); 
            }

            updateSelectionSummary();
            canvas.renderAll();
        }

        function updateSelectionSummary() {
            const count = selectedSeats.length;
            if (count > 0) {
                $('#selection-summary').removeClass('hidden');
                $('#clear-selection').removeClass('hidden');
                $('#selected-count').text(count);
                $('#selected-seats-list').text(selectedSeats.map(id => seatNames[id]).join(', '));
            } else {
                $('#selection-summary').addClass('hidden');
                $('#clear-selection').addClass('hidden');
            }
        }

        function clearAllSelections(canvas) {
            canvas.getObjects('group').forEach(group => {
                if (group.available && group.seatId) {
                    group.item(0).set('fill', '#4CAF50'); 
                }
            });
            selectedSeats = [];
            updateSelectionSummary();
            canvas.renderAll();
        }

        // --- NOTIFICATIONS & MESSAGES ---
        function showLoadingOnFabric(canvas) {
            canvas.add(new fabric.Text('Loading map...', { left: 300, top: 200, originX: 'center', originY: 'center', fill: '#4a5568', fontSize: 18 }));
            canvas.renderAll();
        }
        function showNoSeatsMessageOnFabric(canvas) {
            canvas.add(new fabric.Text('No seats or layout available for this area', { left: 300, top: 200, originX: 'center', originY: 'center', fill: '#666', fontSize: 18 }));
            canvas.renderAll();
        }
        function showErrorMessageOnFabric(canvas) {
            canvas.add(new fabric.Text('Failed to load map data. Please try again.', { left: 300, top: 200, originX: 'center', originY: 'center', fill: '#e53e3e', fontSize: 18 }));
            canvas.renderAll();
        }
        function showNotification(message, type = 'info') {
            $('.notification').remove();
            let bgColor = type === 'success' ? 'bg-green-500' : type === 'error' ? 'bg-red-500' : type === 'warning' ? 'bg-yellow-500' : 'bg-blue-500';
            const notification = $(`<div class="notification fixed top-4 right-4 ${bgColor} text-white px-6 py-3 rounded-lg shadow-lg z-50">${message}</div>`);
            $('body').append(notification);
            setTimeout(() => notification.fadeOut(() => notification.remove()), 5000);
        }
    </script>
}
