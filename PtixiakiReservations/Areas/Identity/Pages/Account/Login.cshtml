@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    var inputClasses = "block h-12 w-full rounded-lg border border-gray-300 bg-white px-4 text-sm text-gray-900 shadow-sm transition focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-600 focus:ring-opacity-10";
}

<style>
    .auth-validation.validation-summary-valid {
        display: none;
    }
</style>

<div class="flex items-center justify-center px-4 py-10" style="min-height: calc(100vh - 220px);">
    <div class="grid w-full max-w-4xl overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-xl lg:grid-cols-2">
        <aside class="hidden bg-gradient-to-br from-blue-600 to-indigo-700 p-8 text-white lg:flex lg:flex-col lg:justify-between">
            <div>
                <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-white bg-opacity-20">
                    <svg class="h-7 w-7" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <circle cx="25" cy="25" r="20" fill="white" opacity="0.95" />
                        <path d="M15 25C15 20.5817 18.5817 17 23 17H27C31.4183 17 35 20.5817 35 25C35 29.4183 31.4183 33 27 33H23C18.5817 33 15 29.4183 15 25Z" fill="#4F46E5" />
                        <path d="M19 21H31V23H19V21Z" fill="white" />
                        <path d="M19 25H31V27H19V25Z" fill="white" />
                        <path d="M19 29H31V31H19V29Z" fill="white" />
                    </svg>
                </div>
                <h1 class="mt-6 text-3xl font-bold tracking-tight">Welcome back</h1>
                <p class="mt-3 text-sm leading-6 text-blue-100">
                    Sign in to continue managing reservations, bookings, and event discovery with EventSphere.
                </p>
            </div>

            <div class="space-y-3 text-sm text-blue-50">
                <div class="flex items-center gap-3">
                    <span class="h-2 w-2 rounded-full bg-white"></span>
                    <span>Discover events faster</span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="h-2 w-2 rounded-full bg-white"></span>
                    <span>Book seats with fewer steps</span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="h-2 w-2 rounded-full bg-white"></span>
                    <span>Receive instant confirmations</span>
                </div>
            </div>
        </aside>

        <section class="p-6 sm:p-8">
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-gray-900">Log in</h2>
                <p class="mt-2 text-sm text-gray-600">Use your EventSphere account to continue.</p>
            </div>

            <form id="account" method="post" class="space-y-5">
                <div asp-validation-summary="All" id="info_text" class="auth-validation rounded-lg border border-red-200 bg-red-50 p-3 text-sm font-medium text-red-700"></div>

                <div>
                    <label asp-for="Input.Email" class="block text-sm font-semibold text-gray-800">
                        Email
                    </label>
                    <input asp-for="Input.Email" class="@inputClasses mt-2" autocomplete="username" />
                    <span asp-validation-for="Input.Email" class="mt-1 block text-xs text-red-600"></span>
                </div>

                <div>
                    <div class="flex items-center justify-between">
                        <label asp-for="Input.Password" class="block text-sm font-semibold text-gray-800">
                            Password
                        </label>
                        <a id="forgot-password" asp-page="./ForgotPassword" class="text-sm font-medium text-blue-600 hover:text-blue-700 hover:underline">
                            Forgot password?
                        </a>
                    </div>
                    <div class="relative mt-2">
                        <input asp-for="Input.Password"
                               type="password"
                               id="passwordInput"
                               class="@inputClasses pr-20"
                               autocomplete="current-password" />
                        <button type="button"
                                id="togglePasswordButton"
                                class="absolute inset-y-1 right-1 inline-flex items-center rounded-md px-3 text-sm font-semibold text-gray-600 hover:bg-gray-100 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-600"
                                aria-controls="passwordInput"
                                aria-label="Show password">
                            Show
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="mt-1 block text-xs text-red-600"></span>
                </div>

                <div class="flex items-center justify-between">
                    <label asp-for="Input.RememberMe" class="inline-flex items-center gap-2 text-sm font-medium text-gray-700">
                        <input asp-for="Input.RememberMe"
                               class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-600" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>

                <button id="loginSubmit" type="submit"
                        class="inline-flex h-12 w-full items-center justify-center rounded-lg bg-blue-600 px-5 text-sm font-semibold text-white shadow-md transition hover:bg-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-600 focus:ring-opacity-20 disabled:cursor-not-allowed disabled:opacity-70">
                    Log in
                </button>

                <div class="border-t border-gray-200 pt-5 text-center text-sm text-gray-600">
                    <span>Don't have an account?</span>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="font-semibold text-blue-600 hover:text-blue-700 hover:underline">
                        Create account
                    </a>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("account");
            const infoText = document.getElementById("info_text");
            const passwordInput = document.getElementById("passwordInput");
            const toggleButton = document.getElementById("togglePasswordButton");
            const submitButton = document.getElementById("loginSubmit");

            toggleButton.addEventListener("click", function () {
                const isHidden = passwordInput.type === "password";
                passwordInput.type = isHidden ? "text" : "password";
                toggleButton.textContent = isHidden ? "Hide" : "Show";
                toggleButton.setAttribute("aria-label", isHidden ? "Hide password" : "Show password");
            });

            form.addEventListener("submit", function (event) {
                let hasError = false;
                let message = "";

                const email = document.querySelector("input[name='Input.Email']");
                const password = document.querySelector("input[name='Input.Password']");

                [email, password].forEach(function (input) {
                    input.classList.remove("border-red-500", "ring-red-100");
                });

                if (!email.value.trim()) {
                    highlight(email);
                    message = "Fill the email field";
                    hasError = true;
                }

                if (!password.value.trim()) {
                    highlight(password);
                    message = message ? "Fill all the fields" : "Fill the password field";
                    hasError = true;
                }

                if (hasError) {
                    event.preventDefault();
                    infoText.textContent = message;
                    return;
                }

                if (typeof $ !== "undefined" && $(form).valid && !$(form).valid()) {
                    return;
                }

                submitButton.disabled = true;
                submitButton.textContent = "Logging in...";
            });

            function highlight(input) {
                input.classList.add("border-red-500", "ring-red-100");
            }
        });
    </script>
}
