@page
@model RegisterModel

@{
    ViewData["Title"] = "Register";
    var inputClasses = "block h-12 w-full rounded-lg border border-gray-300 bg-white px-4 text-sm text-gray-900 shadow-sm transition focus:border-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-600 focus:ring-opacity-10";
}

<style>
    .auth-validation.validation-summary-valid {
        display: none;
    }
</style>

<div class="flex items-center justify-center px-4 py-10" style="min-height: calc(100vh - 220px);">
    <div class="grid w-full max-w-5xl overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-xl lg:grid-cols-2">
        <aside class="hidden bg-gradient-to-br from-blue-600 to-indigo-700 p-8 text-white lg:flex lg:flex-col lg:justify-between">
            <div>
                <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-white bg-opacity-20">
                    <svg class="h-7 w-7" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <circle cx="25" cy="25" r="20" fill="white" opacity="0.95" />
                        <path d="M15 25C15 20.5817 18.5817 17 23 17H27C31.4183 17 35 20.5817 35 25C35 29.4183 31.4183 33 27 33H23C18.5817 33 15 29.4183 15 25Z" fill="#4F46E5" />
                        <path d="M19 21H31V23H19V21Z" fill="white" />
                        <path d="M19 25H31V27H19V25Z" fill="white" />
                        <path d="M19 29H31V31H19V29Z" fill="white" />
                    </svg>
                </div>
                <h1 class="mt-6 text-3xl font-bold tracking-tight">Join EventSphere</h1>
                <p class="mt-3 text-sm leading-6 text-blue-100">
                    Create your account and start booking events with fewer steps and clearer confirmations.
                </p>
            </div>

            <div class="space-y-3 text-sm text-blue-50">
                <div class="flex items-center gap-3">
                    <span class="h-2 w-2 rounded-full bg-white"></span>
                    <span>Discover events that match your plans</span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="h-2 w-2 rounded-full bg-white"></span>
                    <span>Manage bookings from your profile</span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="h-2 w-2 rounded-full bg-white"></span>
                    <span>Get instant reservation confirmations</span>
                </div>
            </div>
        </aside>

        <section class="p-6 sm:p-8">
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-gray-900">Create your account</h2>
                <p class="mt-2 text-sm text-gray-600">Join EventSphere and start booking events.</p>
            </div>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="space-y-5">
                <div asp-validation-summary="All" class="auth-validation rounded-lg border border-red-200 bg-red-50 p-3 text-sm font-medium text-red-700"></div>

                <div>
                    <label asp-for="Input.Email" class="block text-sm font-semibold text-gray-800">Email</label>
                    <input asp-for="Input.Email" class="@inputClasses mt-2" autocomplete="username" />
                    <span asp-validation-for="Input.Email" class="mt-1 block text-xs text-red-600"></span>
                </div>

                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                    <div>
                        <label asp-for="Input.FirstName" class="block text-sm font-semibold text-gray-800">First Name</label>
                        <input asp-for="Input.FirstName" class="@inputClasses mt-2" autocomplete="given-name" />
                        <span asp-validation-for="Input.FirstName" class="mt-1 block text-xs text-red-600"></span>
                    </div>

                    <div>
                        <label asp-for="Input.LastName" class="block text-sm font-semibold text-gray-800">Last Name</label>
                        <input asp-for="Input.LastName" class="@inputClasses mt-2" autocomplete="family-name" />
                        <span asp-validation-for="Input.LastName" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                    <div>
                        <label asp-for="Input.PhoneNumber" class="block text-sm font-semibold text-gray-800">Phone</label>
                        <input asp-for="Input.PhoneNumber" class="@inputClasses mt-2" autocomplete="tel" />
                        <span asp-validation-for="Input.PhoneNumber" class="mt-1 block text-xs text-red-600"></span>
                    </div>

                    <div>
                        <label asp-for="Input.CityId" class="block text-sm font-semibold text-gray-800">City</label>
                        <input id="cityName" class="@inputClasses mt-2" autocomplete="address-level2" placeholder="Search city" />
                        <input type="hidden" asp-for="Input.CityId" id="cityId" />
                        <span asp-validation-for="Input.CityId" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                    <div>
                        <label asp-for="Input.Password" class="block text-sm font-semibold text-gray-800">Password</label>
                        <div class="relative mt-2">
                            <input asp-for="Input.Password"
                                   type="password"
                                   id="registerPasswordInput"
                                   class="@inputClasses pr-20"
                                   autocomplete="new-password" />
                            <button type="button"
                                    class="password-toggle absolute inset-y-1 right-1 inline-flex items-center rounded-md px-3 text-sm font-semibold text-gray-600 hover:bg-gray-100 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-600"
                                    data-target="registerPasswordInput"
                                    aria-controls="registerPasswordInput"
                                    aria-label="Show password">
                                Show
                            </button>
                        </div>
                        <div class="mt-2">
                            <div class="flex gap-1" aria-hidden="true">
                                <span class="strength-segment h-2 flex-1 rounded-full bg-gray-200"></span>
                                <span class="strength-segment h-2 flex-1 rounded-full bg-gray-200"></span>
                                <span class="strength-segment h-2 flex-1 rounded-full bg-gray-200"></span>
                                <span class="strength-segment h-2 flex-1 rounded-full bg-gray-200"></span>
                            </div>
                            <p id="passwordStrengthText" class="mt-1 text-xs font-medium text-gray-500">Password strength</p>
                        </div>
                        <span asp-validation-for="Input.Password" class="mt-1 block text-xs text-red-600"></span>
                    </div>

                    <div>
                        <label asp-for="Input.ConfirmPassword" class="block text-sm font-semibold text-gray-800">Confirm Password</label>
                        <div class="relative mt-2">
                            <input asp-for="Input.ConfirmPassword"
                                   type="password"
                                   id="confirmPasswordInput"
                                   class="@inputClasses pr-20"
                                   autocomplete="new-password" />
                            <button type="button"
                                    class="password-toggle absolute inset-y-1 right-1 inline-flex items-center rounded-md px-3 text-sm font-semibold text-gray-600 hover:bg-gray-100 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-600"
                                    data-target="confirmPasswordInput"
                                    aria-controls="confirmPasswordInput"
                                    aria-label="Show password">
                                Show
                            </button>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="mt-1 block text-xs text-red-600"></span>
                    </div>
                </div>

                <button id="registerSubmit" type="submit"
                        class="inline-flex h-12 w-full items-center justify-center rounded-lg bg-blue-600 px-5 text-sm font-semibold text-white shadow-md transition hover:bg-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-600 focus:ring-opacity-20 disabled:cursor-not-allowed disabled:opacity-70">
                    Register
                </button>

                <div class="border-t border-gray-200 pt-5 text-center text-sm text-gray-600">
                    <span>Already have an account?</span>
                    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="font-semibold text-blue-600 hover:text-blue-700 hover:underline">
                        Log in
                    </a>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="//code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("registerForm");
            const submitButton = document.getElementById("registerSubmit");
            const passwordInput = document.getElementById("registerPasswordInput");
            const strengthSegments = Array.from(document.querySelectorAll(".strength-segment"));
            const strengthText = document.getElementById("passwordStrengthText");

            document.querySelectorAll(".password-toggle").forEach(function (button) {
                button.addEventListener("click", function () {
                    const input = document.getElementById(button.dataset.target);
                    const isHidden = input.type === "password";
                    input.type = isHidden ? "text" : "password";
                    button.textContent = isHidden ? "Hide" : "Show";
                    button.setAttribute("aria-label", isHidden ? "Hide password" : "Show password");
                });
            });

            passwordInput.addEventListener("input", function () {
                const value = passwordInput.value;
                let score = 0;

                if (value.length >= 6) score += 1;
                if (/[A-Z]/.test(value) && /[a-z]/.test(value)) score += 1;
                if (/\d/.test(value)) score += 1;
                if (/[^A-Za-z0-9]/.test(value)) score += 1;

                const labels = ["Password strength", "Weak", "Fair", "Good", "Strong"];
                const colors = ["bg-gray-200", "bg-red-500", "bg-yellow-500", "bg-blue-500", "bg-green-500"];

                strengthSegments.forEach(function (segment, index) {
                    segment.className = "strength-segment h-2 flex-1 rounded-full " + (index < score ? colors[score] : "bg-gray-200");
                });

                strengthText.textContent = labels[score];
                strengthText.className = "mt-1 text-xs font-medium " + (score >= 3 ? "text-green-600" : score > 0 ? "text-yellow-700" : "text-gray-500");
            });

            form.addEventListener("submit", function () {
                if (typeof $ !== "undefined" && $(form).valid && !$(form).valid()) {
                    return;
                }

                submitButton.disabled = true;
                submitButton.textContent = "Creating account...";
            });
        });

        $(function () {
            $("#cityName").autocomplete({
                source: function (request, response) {
                    $.ajax({
                        url: "@Url.Action("SearchCities", "ApplicationUser")",
                        dataType: "json",
                        data: {
                            term: request.term
                        },
                        success: function (data) {
                            response($.map(data, function (item) {
                                return {
                                    label: item.value,
                                    value: item.value,
                                    id: item.id
                                };
                            }));
                        }
                    });
                },
                minLength: 2,
                select: function (event, ui) {
                    $("#cityId").val(ui.item.id);
                    return true;
                },
                change: function (event, ui) {
                    if (!ui.item) {
                        $("#cityId").val("");
                    }
                }
            });
        });
    </script>
}
